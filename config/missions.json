{
  "current_mission": "图片打分任务",
  "missions": {
    "图片打分任务": [
      {
        "name": "1. 识别并点击小图",
        "action": "action_click_landmark",
        "params": {"keywords": ["inputs", "input", "source"]},
        "description": "寻找 Inputs 文字并定位下方图片中心"
      },
      {
        "name": "2. 等待大图弹出",
        "action": "action_wait_visual",
        "params": {"threshold": 15, "timeout": 10},
        "description": "监控页面增量变化，确认大图加载"
      },
      {
        "name": "3. 注入方向键序列",
        "action": "action_press_keys",
        "params": {"keys": ["down", "right", "left", "up"]},
        "description": "物理穿透注入按键流，遍历所有对比图"
      },
      {
        "name": "4. Ref1 放大 / PAN / 还原",
        "action": "action_zoom_pan_reset",
        "params": {
          "landmark_keywords": ["ref1", "ref", "response"],
          "scroll_amount": 3,
          "pan_dx": 80,
          "pan_dy": 40,
          "reset_by_double_click": true
        },
        "description": "点击 Ref1 大图 → 滚轮放大 → 拖拽 PAN → 双击还原"
      },
      {
        "name": "5. Source→Down→ResponseA→圆圈PAN→还原",
        "action": "action_source_navigate_zoom_circle",
        "params": {
          "source_keywords": ["source"],
          "response_keywords": ["response a", "response"],
          "scroll_amount": 4,
          "circle_radius": 70,
          "circle_steps": 24
        },
        "description": "点 SOURCE 缩略图 → ↓ 导航 → 找 Response A 大图 → Zoom → 画圆圈 PAN → 双击还原"
      },
      {
        "name": "6. 最终截图存档",
        "action": "action_screenshot",
        "params": {"label": "result_final"},
        "description": "保存当前屏幕状态作为任务成果"
      }
    ]
  }
}
