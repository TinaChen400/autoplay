{
  "current_mission": "Tina 评分任务",
  "missions": {
    "图片打分任务": [
      {
        "name": "1. 识别并点击小图",
        "action": "action_click_landmark",
        "params": {"keywords": ["inputs", "input", "source"]},
        "description": "寻找 Inputs 文字并定位下方图片中心"
      },
      {
        "name": "2. 注入方向键序列",
        "action": "action_press_keys",
        "params": {"keys": ["down", "right", "left", "up"]},
        "description": "物理穿透注入按键流，遍历所有对比图"
      },
      {
        "name": "7. 最终截图存档",
        "action": "action_screenshot",
        "params": {"label": "result_final"},
        "description": "保存当前屏幕状态作为任务成果"
      }
    ],
    "Tina 评分任务": {
      "id": "tina_marking_v4",
      "steps": [
        {
          "name": "0. 检查并清理弹窗广告",
          "action": "action_click_landmark",
          "params": {"keywords": ["取消", "开通会员"], "optional": true},
          "description": "如果发现向日葵广告弹窗，自动将其关闭"
        },
        {
          "name": "1. 首页截图拍照",
          "action": "action_screenshot",
          "params": {"label": "top"},
          "description": "拍摄页面顶部的证据快照"
        },
        {
          "name": "2. 强力对角并滚动到底部",
          "action": "action_scroll_home_end",
          "params": {"direction": "end"},
          "description": "内容区地标对焦+连发滚动连招"
        },
        {
          "name": "3. 底部截图拍照",
          "action": "action_screenshot",
          "params": {"label": "bottom"},
          "description": "拍摄页面底部的证据快照"
        },
        {
          "name": "4. 返回页面顶部",
          "action": "action_scroll_home_end",
          "params": {"direction": "home"},
          "description": "回到顶部准备定位操作"
        },
        {
          "name": "5. 内容唤醒并点击 Inputs",
          "action": "action_click_landmark_v2",
          "params": {"keywords": ["Omni", "Inputs", "Guidelines", "Earnings"]},
          "description": "增强环境自愈：如果身处 Earnings 页面，以此为锚点强行切回任务页"
        },
        {
          "name": "5.5 加载延时缓冲",
          "action": "action_sleep",
          "params": {"seconds": 3.0},
          "description": "确保页面渲染稳定后再进行按键操作"
        },
        {
          "name": "6. 内部视图导航",
          "action": "action_press_keys",
          "params": {"keys": ["down", "right"]},
          "description": "方向键触发 Response A/B 视图"
        },
        {
          "name": "7. 暴力巡航 Response A",
          "action": "action_zoom_pan_reset",
          "params": {
            "landmark_keywords": ["Response A", "Response"],
            "scroll_amount": 15,
            "pan_dx": 180,
            "pan_dy": 100
          },
          "description": "15倍暴力缩放+大跨度平移巡航"
        },
        {
          "name": "8. 暴力巡航 Response B",
          "action": "action_zoom_pan_reset",
          "params": {
            "landmark_keywords": ["Response B", "Response"],
            "scroll_amount": 15,
            "pan_dx": -180,
            "pan_dy": 100
          },
          "description": "15倍暴力缩放+大跨度平移巡航"
        }
      ]
    }
  }
